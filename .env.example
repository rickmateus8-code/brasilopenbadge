# Cloudflare Pages Functions Environment Variables
# Copy this file to .env and fill in your values for local development

# Database
DATABASE_ID=your_d1_database_id_here

# Environment
ENVIRONMENT=development
API_BASE_URL=http://localhost:8787/api

# Cloudflare Account Info (from wrangler login)
CLOUDFLARE_ACCOUNT_ID=your_account_id_here
CLOUDFLARE_API_TOKEN=your_api_token_here

# Domain Configuration
DOMAIN=atestado-valide.digital
STAGING_DOMAIN=staging.atestado-valide.digital
