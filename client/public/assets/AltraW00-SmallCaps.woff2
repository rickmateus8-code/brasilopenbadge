<!DOCTYPE html>
<html lang="pt-br">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>ELITEDOC.STORE| Dashboard</title>
    <meta name="robots" content="noindex, nofollow">

    <script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
    <script src="https://unpkg.com/pdf-lib@1.17.1/dist/pdf-lib.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/qrcodejs/1.0.0/qrcode.min.js"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700&display=swap" rel="stylesheet">
    <script src="https://unpkg.com/@pdf-lib/fontkit/dist/fontkit.umd.min.js"></script>
    <style>
        :root {
            --primary: #2563eb;
            --primary-dark: #1e40af;
            --success: #22c55e;
            --warning: #f59e0b;
            --danger: #ef4444;
            --bg-main: #f8fafc;
            --bg-card: #ffffff;
            --text-main: #1e293b;
            --text-muted: #64748b;
            --sidebar-bg: #0f172a;
            --sidebar-text: #f8fafc;
            --border-color: #e2e8f0;
        }

        * {
            box-sizing: border-box !important;
        }

        div.swal2-container {
            z-index: 99999 !important;
        }

        .modal-overlay {
            z-index: 9999;
        }

        body {
            font-family: 'Inter', sans-serif;
            background-color: var(--bg-main);
            color: var(--text-main);
            margin: 0;
            display: flex;
            overflow-x: hidden;
        }

        .sidebar {
            width: 260px;
            background: var(--sidebar-bg);
            color: var(--sidebar-text);
            display: flex;
            flex-direction: column;
            position: fixed;
            height: 100vh;
            z-index: 100;
        }

        .sidebar-header {
            padding: 25px 20px;
            text-align: center;
            border-bottom: 1px solid rgba(255, 255, 255, 0.1);
        }

        .user-info {
            padding: 20px;
            display: flex;
            align-items: center;
            gap: 12px;
            position: relative;
        }

        .user-avatar {
            width: 35px;
            height: 35px;
            background: var(--primary);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .btn-change-pass {
            background: rgba(255, 255, 255, 0.1);
            border: none;
            color: #cbd5e1;
            width: 25px;
            height: 25px;
            border-radius: 50%;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            margin-left: auto;
        }

        .btn-novo-doc-sidebar {
            background: var(--primary);
            color: white;
            margin: 0 20px 20px;
            padding: 12px;
            border-radius: 8px;
            font-weight: 700;
            text-align: center;
            cursor: pointer;
            border: none;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
        }

        .saldo-box {
            margin: 0 20px 10px;
            padding: 10px 15px;
            background: linear-gradient(135deg, rgba(30, 41, 59, 0.7), rgba(15, 23, 42, 0.9));
            border: 1px solid rgba(59, 130, 246, 0.3);
            border-radius: 8px;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .saldo-label {
            font-size: 11px;
            font-weight: 700;
            color: #94a3b8;
        }

        .saldo-valor {
            font-size: 16px;
            font-weight: 800;
            color: #fff;
        }

        .btn-credits-menu {
            background: rgba(255, 255, 255, 0.1);
            margin: 0 20px 15px;
            border-radius: 8px;
            font-size: 12px;
            font-weight: bold;
            color: white;
            text-align: center;
            padding: 10px;
            cursor: pointer;
            border: 1px solid rgba(255, 255, 255, 0.2);
        }

        .menu-scroll {
            flex: 1;
            padding: 10px 0;
            overflow-y: auto;
            display: flex;
            flex-direction: column;
        }

        .divider {
            padding: 10px 25px;
            font-size: 11px;
            text-transform: uppercase;
            color: #475569;
            font-weight: 700;
            margin-top: 10px;
        }

        .menu-item {
            padding: 12px 25px;
            cursor: pointer;
            display: flex;
            align-items: center;
            gap: 12px;
            color: #cbd5e1;
            border-left: 4px solid transparent;
            transition: 0.2s;
        }

        .menu-item:hover {
            background: rgba(255, 255, 255, 0.05);
            color: white;
            padding-left: 30px;
        }

        .menu-item.active {
            border-left-color: var(--primary);
            background: rgba(59, 130, 246, 0.1);
            color: white;
            font-weight: 600;
        }

        .main-content {
            margin-left: 260px;
            flex: 1;
            padding: 30px;
            min-height: 100vh;
        }

        .page-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 30px;
            flex-wrap: wrap;
            gap: 15px;
        }

        .top-buttons {
            display: flex;
            gap: 10px;
        }

        .stats-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
            gap: 20px;
            margin-bottom: 30px;
        }

        .stat-card {
            background: var(--bg-card);
            padding: 20px;
            border-radius: 12px;
            box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
            display: flex;
            align-items: center;
            gap: 20px;
            border: 1px solid var(--border-color);
        }

        .card {
            background: var(--bg-card);
            border-radius: 12px;
            padding: 20px;
            box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
            border: 1px solid var(--border-color);
        }

        table {
            width: 100%;
            border-collapse: collapse;
            margin-top: 10px;
        }

        th {
            background: #f8fafc;
            text-align: left;
            padding: 12px;
            font-size: 11px;
            text-transform: uppercase;
            color: var(--text-muted);
            border-bottom: 1px solid var(--border-color);
        }

        td {
            padding: 12px;
            font-size: 13px;
            border-bottom: 1px solid var(--border-color);
            vertical-align: middle;
        }

        tr:hover {
            background-color: #f8fafc;
        }

        .search-box {
            position: relative;
            width: 100%;
            margin: 15px 0;
        }

        .search-box input {
            width: 100%;
            padding: 12px 12px 12px 42px;
            border-radius: 10px;
            border: 1px solid var(--border-color);
            font-size: 14px;
            outline: none;
        }

        .search-box i {
            position: absolute;
            left: 15px;
            top: 50%;
            transform: translateY(-50%);
            color: var(--text-muted);
        }

        .btn {
            padding: 10px 16px;
            border-radius: 8px;
            border: none;
            cursor: pointer;
            font-weight: 600;
            font-size: 13px;
            display: inline-flex;
            align-items: center;
            gap: 8px;
            transition: 0.2s;
        }

        .btn-primary {
            background: var(--primary);
            color: white;
        }

        .btn-outline {
            background: transparent;
            border: 1px solid var(--border-color);
            color: var(--text-main);
        }

        .action-btn {
            width: 32px;
            height: 32px;
            border-radius: 6px;
            border: none;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            color: white;
            margin-left: 3px;
        }

        .modal-overlay {
            position: fixed;
            inset: 0;
            background: rgba(0, 0, 0, 0.85);
            display: none;
            align-items: center;
            justify-content: center;
            backdrop-filter: blur(4px);
        }

        .modal-content-large {
            background: white;
            padding: 25px;
            border-radius: 12px;
            width: 500px;
            max-width: 90%;
            text-align: left;
            position: relative;
            max-height: 80vh;
            overflow-y: auto;
            display: flex;
            flex-direction: column;
        }

        .doc-options-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 15px;
            margin-top: 20px;
        }

        .doc-btn-big {
            display: flex !important;
            flex-direction: column !important;
            align-items: center !important;
            justify-content: center !important;
            text-align: center !important;
            padding: 20px;
            background: #f8fafc;
            border: 1px solid #e2e8f0;
            border-radius: 12px;
            cursor: pointer;
            transition: 0.2s;
            color: var(--text-main);
        }

        .doc-price-tag {
            display: inline-block !important;
            width: fit-content !important;
            margin: 8px auto 0 auto !important;
            font-size: 12px;
            color: var(--success);
            font-weight: 600;
            background: rgba(34, 197, 94, 0.1);
            padding: 4px 12px;
            border-radius: 10px;
        }

        .mobile-header-info,
        .mobile-logout-btn {
            display: none;
        }

        #login-overlay {
            display: flex;
            flex-direction: column;
            position: fixed;
            inset: 0;
            background: var(--sidebar-bg);
            align-items: center;
            justify-content: center;
            z-index: 10000;
        }

        .area-texto-zap {
            width: 100%;
            height: 150px;
            background: #f8fafc;
            border: 1px solid #cbd5e1;
            border-radius: 8px;
            padding: 15px;
            resize: none;
            margin: 15px 0;
        }

        .selector-container {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
            margin: 20px 0;
            background: #f1f5f9;
            padding: 10px;
            border-radius: 12px;
        }

        .btn-control {
            width: 45px;
            height: 45px;
            border-radius: 10px;
            border: none;
            background: white;
            color: var(--primary);
            font-size: 24px;
            font-weight: bold;
            cursor: pointer;
        }

        #valorInput {
            width: 140px !important;
            text-align: center;
            font-size: 22px;
            font-weight: 800;
            border: none;
            background: transparent;
        }

        .menu-scroll-horizontal {
            display: flex;
            gap: 8px;
            background: var(--bg-main);
            padding: 8px;
            border-radius: 12px;
            overflow-x: auto;
            white-space: nowrap;
            -webkit-overflow-scrolling: touch;
            scrollbar-width: none;
        }


        @media (max-width: 768px) {

            body {
                padding-bottom: 0;
            }

            .sidebar {
                top: auto;
                bottom: 0;
                height: 70px;
                width: 100%;
                flex-direction: row;
                justify-content: space-around;
                padding: 0;
                border-top: 1px solid rgba(255, 255, 255, 0.1);
                background: #0f172a;
                box-shadow: 0 -4px 10px rgba(0, 0, 0, 0.3);
            }

            .sidebar-header,
            .user-info,
            .saldo-box,
            .btn-credits-menu,
            .btn-novo-doc-sidebar,
            .divider,
            .menu-item[onclick*="logout"] {
                display: none !important;
            }

            .menu-scroll {
                flex-direction: row;
                width: 100%;
                justify-content: space-around;
                padding: 0;
                overflow: visible;
                align-items: center;
            }

            .menu-item {
                flex-direction: column;
                gap: 4px;
                padding: 8px;
                font-size: 10px;
                border-left: none;
                margin: 0;
                opacity: 0.7;
            }

            .menu-item.active {
                background: transparent;
                color: var(--primary);
                opacity: 1;
                border-bottom: none;
                border-top: 3px solid var(--primary);
            }

            .fab-mobile {
                position: fixed;
                bottom: 85px;
                right: 20px;
                width: 55px;
                height: 55px;
                background: var(--primary);
                border-radius: 50%;
                color: white;
                display: flex;
                align-items: center;
                justify-content: center;
                box-shadow: 0 4px 10px rgba(37, 99, 235, 0.4);
                font-size: 24px;
                border: none;
                z-index: 99;
            }

            .main-content {
                margin-left: 0;
                padding: 15px 15px 120px 15px;
                width: 100%;
            }

            .mobile-header-info {
                display: flex;
                justify-content: space-between;
                align-items: center;
                background: var(--bg-card);
                padding: 15px;
                border-radius: 12px;
                border: 1px solid var(--border-color);
                margin-bottom: 10px;
            }

            .mob-saldo-label {
                font-size: 10px;
                color: var(--text-muted);
                font-weight: bold;
            }

            .mob-saldo-valor {
                font-size: 20px;
                font-weight: 800;
                color: var(--success);
            }

            .btn-mob-add {
                background: var(--primary);
                color: white;
                border-radius: 50%;
                width: 40px;
                height: 40px;
                border: none;
                display: flex;
                align-items: center;
                justify-content: center;
            }

            .mobile-logout-btn {
                display: flex;
                width: 40px;
                height: 40px;
                background: rgba(239, 68, 68, 0.1);
                color: var(--danger);
                border-radius: 8px;
                border: none;
                align-items: center;
                justify-content: center;
            }

            table,
            thead,
            tbody,
            th,
            td,
            tr {
                display: block !important;
                width: 100% !important;
            }

            thead {
                display: none !important;
            }

            tr {
                background: #ffffff !important;
                border: 1px solid #e2e8f0 !important;
                border-radius: 12px !important;
                margin-bottom: 20px !important;
                padding: 15px !important;
                box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05) !important;
                height: auto !important;
                position: relative !important;
            }

            td {
                padding: 8px 0 !important;
                border: none !important;
                border-bottom: 1px dashed #f1f5f9 !important;
                text-align: right !important;
                font-size: 14px !important;
                display: flex !important;
                justify-content: space-between !important;
                align-items: center !important;
                width: 100% !important;
                white-space: normal !important;
            }

            td:nth-of-type(1)::before {
                content: "Nome";
                font-weight: 700;
                color: #64748b;
                font-size: 12px;
                text-transform: uppercase;
            }

            td:nth-of-type(2)::before {
                content: "Doc/Ref";
                font-weight: 700;
                color: #64748b;
                font-size: 12px;
                text-transform: uppercase;
            }

            td:nth-of-type(3)::before {
                content: "Data";
                font-weight: 700;
                color: #64748b;
                font-size: 12px;
                text-transform: uppercase;
            }

            td:nth-of-type(1) {
                color: var(--primary-dark);
                font-weight: 700;
                font-size: 15px;
                text-align: right !important;
            }

            td:last-child {
                border-bottom: none !important;
                justify-content: flex-end !important;
                gap: 8px !important;
                padding-top: 15px !important;
                margin-top: 5px !important;
                flex-wrap: wrap !important;
            }

            td:last-child::before {
                display: none !important;
            }
        }
    </style>
</head>

<body>

    <div id="login-overlay">
        <div class="card" style="width: 350px; text-align: center; position: relative; overflow: hidden;">

            <h2 style="margin-bottom: 20px; color: #333;">ELITEDOC<span style="color:var(--primary)">.STORE</span></h2>

            <div id="area-login">
                <form onsubmit="event.preventDefault(); loginReal();" id="login-form">
                    <input type="email" id="email" name="email" autocomplete="username" placeholder="E-mail"
                        style="width: 100%; padding: 12px; margin-bottom: 10px; border-radius: 8px; border: 1px solid #ccc;">
                    <input type="password" id="pass" name="password" autocomplete="current-password" placeholder="Senha"
                        style="width: 100%; padding: 12px; margin-bottom: 20px; border-radius: 8px; border: 1px solid #ccc;">
                    <button type="submit" class="btn btn-primary" style="width: 100%; justify-content: center;">
                        ACESSAR PAINEL
                    </button>
                </form>

                <div style="margin-top: 20px; border-top: 1px solid #eee; padding-top: 15px;">
                    <p style="font-size: 13px; color: #64748b; margin-bottom: 10px;">Não tem acesso?</p>
                    <button class="btn btn-outline" style="width: 100%; justify-content: center;"
                        onclick="alternarTelaLogin('cadastro')">
                        CRIAR CONTA
                    </button>
                </div>
            </div>

            <div id="area-cadastro" style="display: none;">
                <p style="font-size: 14px; color: #64748b; margin-bottom: 15px;">Informe seu vulgo para solicitar
                    acesso.</p>

                <input type="text" id="reg-vulgo" placeholder="Digite seu Vulgo / Apelido"
                    style="width: 100%; padding: 12px; margin-bottom: 20px; border-radius: 8px; border: 1px solid #ccc; text-align: center; font-weight: bold; text-transform: uppercase;">

                <button class="btn"
                    style="width: 100%; justify-content: center; background-color: #25D366; color: white; margin-bottom: 10px;"
                    onclick="enviarPedidoZap()">
                    <i class="fab fa-whatsapp"></i> SOLICITAR ACESSO
                </button>

                <button class="btn-outline"
                    style="width: 100%; padding: 10px; border: none; background: transparent; color: #64748b; cursor: pointer; font-size: 12px;"
                    onclick="alternarTelaLogin('login')">
                    Voltar para Login </button>
            </div>

            <p id="login-error" style="color: red; font-size: 12px; margin-top: 10px;"></p>
        </div>

        <div
            style="margin-top: 20px; font-size: 11px; color: #94a3b8; font-weight: 600; text-align: center; letter-spacing: 1px; text-transform: uppercase;">
            created by <span style="color: #2563eb;">x_Dev</span>
        </div>
    </div>

    <div class="sidebar">
        <div class="sidebar-header">
            <h2 style="font-size: 16px; font-weight: 700; letter-spacing: 1px;">
                ELITEDOC<span style="color:var(--primary);">.STORE</span>
            </h2>
        </div>
        <div class="user-info">
            <div class="user-avatar"><i class="fas fa-user"></i></div>
            <div style="overflow: hidden; max-width: 130px;">
                <div id="user-email-display" style="font-size: 11px; font-weight: 600;">...</div>
            </div>
            <button class="btn-change-pass" onclick="abrirModalSenha()" title="Alterar Senha"><i class="fas fa-lock"
                    style="font-size: 12px;"></i></button>
        </div>

        <button class="btn-novo-doc-sidebar" onclick="abrirModalSelecao()">
            <i class="fas fa-plus-circle"></i> NOVO DOCUMENTO
        </button>

        <div class="saldo-box">
            <div class="saldo-label"><i class="fas fa-wallet"></i> SALDO</div>
            <div class="saldo-valor" id="display-saldo">R$ 0,00</div>
        </div>
        <div class="btn-credits-menu" onclick="abrirModalRecarga()"><i class="fas fa-plus-circle"></i> RECARREGAR
        </div>

        <div class="menu-scroll">
            <div class="divider">Principal</div>
            <div class="menu-item active" onclick="mudarTab(activeTab); carregarDados();"><i class="fas fa-home"></i>
                <span>Dashboard</span>
            </div>
        </div>

        <div class="menu-item" onclick="logout()"
            style="color: #fca5a5; margin-top: auto; border-top: 1px solid rgba(255,255,255,0.1);"><i
                class="fas fa-sign-out-alt"></i> <span>Sair</span></div>
    </div>

    <button class="fab-mobile" onclick="abrirModalSelecao()" title="Novo Documento"><i class="fas fa-plus"></i></button>

    <div class="main-content">
        <div class="page-header">
            <div style="display:flex; align-items:center; gap:10px; width: 100%; justify-content: space-between;">
                <h1 style="margin:0; font-size:22px;">Visão Geral</h1>
                <button class="mobile-logout-btn" onclick="logout()"><i class="fas fa-sign-out-alt"></i></button>
            </div>
            <div class="mobile-header-info" style="width: 100%; margin-top: 10px;">
                <div>
                    <div class="mob-saldo-label">SEU SALDO</div>
                    <div class="mob-saldo-valor" id="mob-display-saldo">R$ --</div>
                </div>
                <button class="btn-mob-add" onclick="abrirModalRecarga()"><i class="fas fa-plus"></i></button>
            </div>
            <div class="top-buttons" style="width: 100%; margin-top: 10px; display: flex; gap: 10px;">
                <button class="btn btn-outline" onclick="verTextoSistema('instrucoes')">
                    <i class="fas fa-book"></i> Instruções
                </button>

                <button class="btn btn-outline" onclick="verTextoSistema('novidades')">
                    <i class="fas fa-bell"></i> Novidades
                </button>

                <button class="btn btn-outline" onclick="abrirModalSuporte()">
                    <i class="fas fa-headset"></i> Suporte
                </button>
            </div>
        </div>

        <div class="stats-grid">
            <div class="stat-card">
                <div class="stat-icon"
                    style="background: rgba(34,197,94,0.1); color: var(--success); width:50px; height:50px; border-radius:10px; display:flex; align-items:center; justify-content:center;">
                    <i class="fas fa-check-circle" style="font-size:20px;"></i>
                </div>
                <div>
                    <div class="saldo-label" id="label-ativa">Documentos Ativos</div>
                    <div id="total-ativa" style="font-size: 20px; font-weight: 700; color:var(--text-main)">--</div>
                </div>
            </div>
        </div>

        <div class="card">
            <div
                style="display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 10px; margin-bottom:15px;">
                <h2 style="font-size: 18px; margin: 0;">Meus Documentos</h2>

                <div class="menu-scroll-horizontal">
                    <button id="tab-cnh" class="btn" onclick="mudarTab('CNH')">CNH</button>
                    <button id="tab-rg" class="btn" onclick="mudarTab('RG')">RG</button>
                    <button id="tab-cha" class="btn btn-outline" onclick="mudarTab('CHA')"><i class="fas fa-ship"></i>
                        CHA</button>
                    <button id="tab-crlv" class="btn btn-outline" onclick="mudarTab('CRLV')"><i class="fas fa-car"></i>
                        CRLV</button>
                    <button id="tab-recibo" class="btn btn-outline" onclick="mudarTab('RECIBO')"><i
                            class="fas fa-file-signature"></i> RECIBO (ATPV-e)</button>
                    <button id="tab-atestado" class="btn btn-outline" onclick="mudarTab('ATESTADO')"><i
                            class="fas fa-user-md"></i> ATESTADO</button>
                    <button id="tab-toxicologico" class="btn btn-outline" onclick="mudarTab('TOXICOLOGICO')"><i
                            class="fas fa-flask"></i> TOXICOLÓGICO</button>
                    <button id="tab-diploma" class="btn btn-outline" onclick="mudarTab('DIPLOMA')"><i
                            class="fas fa-graduation-cap"></i> DIPLOMA</button>

                    <button id="tab-historico" class="btn btn-outline" onclick="mudarTab('HISTORICO')"><i
                            class="fas fa-file-alt"></i> HISTÓRICO</button>
                </div>
            </div>

            <div class="search-box">
                <i class="fas fa-search"></i>
                <input type="text" id="search-input" onkeyup="filtrarTabela()" placeholder="Buscar por Nome ou CPF...">
            </div>

            <table>
                <thead>
                    <tr>
                        <th>Nome</th>
                        <th>CPF / Documento</th>
                        <th>Criado Em</th>
                        <th style="text-align: right;">Ações</th>
                    </tr>
                </thead>
                <tbody id="tabela-corpo">
                    <tr>
                        <td colspan="4" style="text-align:center">Carregando...</td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>

    <div id="modal-selecao" class="modal-overlay" onclick="fecharModalFora(event, 'modal-selecao')">
        <div class="modal-content-large" style="width: 500px;">
            <div style="display:flex; justify-content:space-between; align-items:center;">
                <h3 style="margin:0; color:var(--primary);">Novo Documento</h3>
                <button onclick="fecharModal('modal-selecao')"
                    style="border:none; background:none; font-size:24px; cursor:pointer;">&times;</button>
            </div>
            <p style="color:var(--text-muted); font-size:14px; margin-bottom:10px;">O que você deseja emitir hoje?
            </p>

            <div class="doc-options-grid">
                <div class="doc-btn-big" onclick="verificarSaldoERedirecionar('cnhcria.html', 'CNH')">
                    <i class="fas fa-address-card"></i>
                    <span>CNH Digital</span>
                    <div class="doc-price-tag" id="price-card-cnh">R$ 20,00</div>
                </div>
                <div class="doc-btn-big" onclick="verificarSaldoERedirecionar('rgcria.html', 'RG')">
                    <i class="fas fa-id-card"></i>
                    <span>RG (CIN)</span>
                    <div class="doc-price-tag" id="price-card-rg">R$ 20,00</div>
                </div>
                <div class="doc-btn-big" onclick="verificarSaldoERedirecionar('chacria.html', 'CHA')">
                    <i class="fas fa-ship"></i>
                    <span>Arrais (CHA)</span>
                    <div class="doc-price-tag" id="price-card-cha">R$ 30,00</div>
                </div>
                <div class="doc-btn-big" onclick="verificarSaldoERedirecionar('crlvcria.html', 'CRLV')">
                    <i class="fas fa-car"></i>
                    <span>
                        <p>CRLV 2026 <br> S/QRcode
                        <p>
                    </span>
                    <div class="doc-price-tag" id="price-card-crlv">R$ 15,00</div>
                    <div class="doc-btn-big" onclick="verificarSaldoERedirecionar('atpve.html', 'RECIBO')">
                        <i class="fas fa-file-signature"></i>
                        <span>
                            <p>Recibo Venda<br>(ATPV-e)</p>
                        </span>
                        <div class="doc-price-tag" id="price-card-recibo">R$ 15,00</div>
                    </div>
                </div>
                <div class="doc-btn-big" onclick="verificarSaldoERedirecionar('atestadocria.html', 'ATESTADO')">
                    <i class="fas fa-user-md"></i>
                    <span>
                        <p>Atestado Médico <br>C e S/QRcode
                        <p>
                    </span>
                    <div class="doc-price-tag" id="price-card-atestado">R$ 20,00</div>
                </div>
                <div class="doc-btn-big" onclick="verificarSaldoERedirecionar('toxicria.html', 'TOXICOLOGICO')">
                    <i class="fas fa-flask"></i>
                    <span>
                        <p>Exame Toxicológico <br>C/QRcode
                        <p></p>
                    </span>
                    <div class="doc-price-tag" id="price-card-toxicologico">R$ 20,00</div>
                </div>
                <div class="doc-btn-big" onclick="verificarSaldoERedirecionar('criadip.html', 'DIPLOMA')">
                    <i class="fas fa-graduation-cap"></i>
                    <span>Diploma Digital</span>
                    <p class="text-[10px] text-center text-gray-500">UNINTER C/QR code </p>
                    <div class="doc-price-tag" id="price-card-diploma">R$ 20,00</div>
                </div>

                <div class="doc-btn-big" onclick="verificarSaldoERedirecionar('historico.html', 'HISTORICO')">
                    <i class="fas fa-file-alt"></i>
                    <span>Histórico Escolar</span>
                    <div class="doc-price-tag" id="price-card-historico">R$ 20,00</div>
                </div>
            </div>


        </div>
    </div>
    </div>

    <div id="modal-msg-sistema" class="modal-overlay" onclick="fecharModalFora(event, 'modal-msg-sistema')">
        <div class="modal-content-large">
            <div style="display:flex; justify-content:space-between; align-items:center;">
                <h3 style="margin:0; color:var(--primary-dark);" id="titulo-msg-sis"></h3>
                <button onclick="fecharModal('modal-msg-sistema')"
                    style="border:none; background:none; font-size:24px; cursor:pointer;">&times;</button>
            </div>
            <div id="conteudo-msg-sis" class="conteudo-scroll"></div>
            <div id="paginacao-instrucoes" class="paginacao-footer" style="display: none;">
                <button class="btn btn-outline" id="btn-ant" onclick="mudarPagina(-1)">Anterior</button>
                <span id="indicador-pagina" style="font-size:12px; font-weight:bold; color:#64748b;">1/1</span>
                <button class="btn btn-primary" id="btn-prox" onclick="mudarPagina(1)"
                    style="width:auto;">Próximo</button>
            </div>
            <button id="btn-unico-msg" class="btn btn-primary"
                style="width: 100%; justify-content: center; margin-top: 15px; display:none;"
                onclick="fecharModal('modal-msg-sistema')">ENTENDI</button>
        </div>
    </div>

    <div id="modal-whatsapp" class="modal-overlay" onclick="fecharModalFora(event, 'modal-whatsapp')">
        <div class="card" style="width: 500px; max-width: 90%;">
            <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:15px;">
                <h3>Enviar Acesso</h3>
                <button onclick="fecharModal('modal-whatsapp')"
                    style="border:none; background:none; font-size:24px;">&times;</button>
            </div>
            <textarea id="texto-whatsapp" class="area-texto-zap" readonly></textarea>
            <div style="display:grid; grid-template-columns: 1fr 1fr; gap:15px;">
                <button class="btn" style="background:#cbd5e1;" onclick="copiarTextoZap()">COPIAR</button>
                <button class="btn" style="background:#25D366; color:white;" onclick="enviarZapReal()">ENVIAR</button>
            </div>
