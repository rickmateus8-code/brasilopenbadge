    <div id="modal-senha" class="modal-overlay" onclick="fecharModalFora(event, 'modal-senha')">
        <div class="card" style="width: 400px; max-width: 90%;">
            <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:15px;">
                <h3 style="margin:0; color:var(--primary);"><i class="fas fa-lock"></i> Alterar Senha</h3>
                <button onclick="fecharModal('modal-senha')"
                    style="border:none; background:none; font-size:24px; cursor:pointer;">&times;</button>
            </div>
            <p style="font-size:13px; color:var(--text-muted);">Digite sua nova senha abaixo.</p>
            <form onsubmit="event.preventDefault(); salvarNovaSenha();">
                <input type="text" name="username" autocomplete="username" style="display:none;">
                <input type="password" id="nova-senha" autocomplete="new-password" placeholder="Nova Senha"
                    style="width: 100%; padding: 10px; margin: 15px 0;">
                <button type="submit" class="btn btn-primary" style="width: 100%;">SALVAR</button>
            </form>
        </div>
    </div>

    <div id="modal-recarga" class="modal-overlay">
        <div class="card" style="width: 340px; max-width: 90%; padding: 20px; position: relative; border-radius: 16px;">

            <button onclick="fecharModalRecarga()"
                style="position: absolute; top: 12px; right: 12px; background: #f1f5f9; border: none; width: 30px; height: 30px; border-radius: 50%; color: #64748b; font-size: 16px; cursor: pointer; display: flex; align-items: center; justify-content: center; z-index: 10;">
                <i class="fas fa-times"></i>
            </button>

            <h3 style="margin-top: 0; margin-bottom: 5px; font-size: 18px; color: #334155; text-align: center;">
                Recarga Rápida
            </h3>
            <p style="text-align: center; color: #94a3b8; font-size: 12px; margin-bottom: 20px;">
                Saldo disponível imediatamente.
            </p>

            <div id="painel-selecao" style="display: block;">
                <div class="selector-container" style="margin: 0 0 15px 0; background: #f8fafc; padding: 15px;">
                    <button class="btn-control" onclick="ajustarValor(-10)"
                        style="width: 35px; height: 35px; font-size: 18px;">-</button>
                    <input type="text" id="valorInput" value="R$ 20,00" readonly
                        style="font-size: 24px; width: 120px !important; color: var(--primary-dark);">
                    <button class="btn-control" onclick="ajustarValor(10)"
                        style="width: 35px; height: 35px; font-size: 18px;">+</button>
                </div>

                <button id="btn-gerar-pix" class="btn btn-primary"
                    style="width: 100%; height: 45px; font-size: 14px; text-transform: uppercase; letter-spacing: 0.5px;"
                    onclick="gerarPixReal()">
                    <i class="fas fa-qrcode"></i> Gerar Pix Copia e Cola
                </button>
            </div>

            <div id="area-pix" style="display: none; text-align: center;">

                <div class="timer-box" id="cronometro"
                    style="font-size: 24px; font-weight: 800; margin: 0 auto 15px auto; color: #ef4444; background: transparent; border: none;">
                    03:00
                </div>

                <div
                    style="margin: 10px auto; width: 180px; height: 180px; display: flex; align-items: center; justify-content: center;">
                    <div id="qr-display-container"></div>
                </div>

                <input type="text" id="pix-copy" readonly
                    style="width: 100%; margin: 15px 0; padding: 12px; border: 1px solid #cbd5e1; border-radius: 6px; text-align: center; background: #f1f5f9; font-size: 11px; color: #475569;">

                <button class="btn btn-success" onclick="copiarPix()"
                    style="width: 100%; justify-content: center; height: 40px; margin-bottom: 15px;">
                    <i class="far fa-copy"></i> Copiar Código
                </button>

                <div style="background: #ffffff; border: 1px solid #eeeeee; border-radius: 8px; padding: 10px;">
                    <p style="margin: 0; font-size: 10px; color: #be123c; font-weight: 700; text-transform: uppercase;">
                        <i class="fas fa-exclamation-triangle"></i> Importante
                    </p>
                    <p style="margin: 4px 0 0 0; font-size: 10px; color: #0d53c3; line-height: 1.4;">
                        Não realizamos estorno e nem fazemos transferências de saldo.
                    </p>
                </div>

            </div>
        </div>
    </div>
    <div id="modalSuporte" class="modal-overlay" onclick="fecharModalFora(event, 'modalSuporte')">
        <div class="card" style="width: 400px; max-width: 90%;">

            <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:20px;">
                <h3 style="margin:0; color:var(--primary); display:flex; align-items:center; gap:10px;">
                    <i class="fas fa-headset"></i> Central de Suporte
                </h3>
                <button onclick="fecharModal('modalSuporte')"
                    style="border:none; background:none; font-size:24px; cursor:pointer; color: #64748b;">
                    &times;
                </button>
            </div>

            <div id="botoesSuporteContainer" style="display: flex; flex-direction: column; gap: 12px;">
                <p style="text-align:center; color:#64748b;">Carregando contatos...</p>
            </div>

        </div>
    </div>

    <script>
        const SUPABASE_URL = 'https://ijkzwzvanougkjcxquvn.supabase.co';
        const SUPABASE_KEY = 'sb_publishable_x76vx-9M9DrmibJ6NeELJg_iT1_CDsT';

        window.supabaseClient = supabase.createClient(SUPABASE_URL, SUPABASE_KEY);
        window._supabase = window.supabaseClient;

        let userSession = null, activeTab = 'CNH', monitoramentoPix = null, timerInterval = null, saldoAtual = 0.00, valorSelecionado = 20.00;
        let sistemaTextos = { instrucoes: '...', novidades: '...' };

        let PRECOS_SISTEMA = {
            'CNH': 20.00,
            'RG': 20.00,
            'CHA': 30.00,
            'CRLV': 30.00,
            'ATESTADO': 20.00,
            'TOXICOLOGICO': 20.00,
            'DIPLOMA': 20.00,
            'RECIBO': 15.00,
            'HISTORICO': 20.00
        };

        window.onload = async () => {
            const { data, error } = await supabaseClient.auth.getSession();
            if (error || !data.session) {
                localStorage.clear();
                document.getElementById('login-overlay').style.display = 'flex';
            } else {
                userSession = data.session.user;
                liberarAcesso();
            }
            supabaseClient.auth.onAuthStateChange((event, session) => {
                if (event === 'SIGNED_IN' && session) { userSession = session.user; liberarAcesso(); }
                else if (event === 'SIGNED_OUT') { location.reload(); }
            });
        };

        function liberarAcesso() {
            document.getElementById('login-overlay').style.display = 'none';
            if (document.getElementById('user-email-display')) document.getElementById('user-email-display').innerText = userSession.email;
            carregarPrecos(); carregarSaldo(); mudarTab(activeTab); carregarAvisoSistema();
        }

        async function loginReal() {
            const email = document.getElementById('email').value;
            const pass = document.getElementById('pass').value;
            const btn = document.querySelector('#login-form button');
            if (!email || !pass) return Swal.fire('Ops', 'Preencha email e senha', 'warning');
            btn.disabled = true; btn.innerText = "Verificando...";
            const { error } = await supabaseClient.auth.signInWithPassword({ email, password: pass });
            if (error) { document.getElementById('login-error').innerText = "Credenciais inválidas."; btn.disabled = false; btn.innerText = "ACESSAR PAINEL"; } else { location.reload(); }
        }

        async function carregarSaldo() {
            if (!userSession) return;
            const { data } = await supabaseClient.from('perfis').select('saldo_creditos').eq('id', userSession.id).single();
            if (data) {
                saldoAtual = parseFloat(data.saldo_creditos || 0);
                const saldoFormatado = saldoAtual.toLocaleString('pt-BR', { style: 'currency', currency: 'BRL' });
                document.getElementById('display-saldo').innerText = saldoFormatado;
                document.getElementById('mob-display-saldo').innerText = saldoFormatado;
            }
        }

        async function verificarSaldoERedirecionar(url, tipoDoc) {
            const modalSel = document.getElementById('modal-selecao');
            if (modalSel) modalSel.style.display = 'none';

            let precoMinimo = PRECOS_SISTEMA[tipoDoc] || 20.00;

            try {
                const { data: { user } } = await supabaseClient.auth.getUser();
                if (!user) { window.location.href = 'index.html'; return; }

                const { data: perfil } = await supabaseClient
                    .from('perfis')
                    .select('saldo_creditos')
                    .eq('id', user.id)
                    .single();

                const saldoReal = perfil ? parseFloat(perfil.saldo_creditos) : 0;

                if (saldoReal < precoMinimo) {
                    Swal.fire({
                        title: 'Saldo Insuficiente',
                        text: `O valor deste documento é ${precoMinimo.toLocaleString('pt-BR', { style: 'currency', currency: 'BRL' })}. Seu saldo é insuficiente.`,
                        icon: 'warning',
                        showCancelButton: true,
                        confirmButtonText: 'Recarregar Agora',
                        confirmButtonColor: '#22c55e',
                        cancelButtonText: 'Cancelar'
                    }).then((result) => {
                        if (result.isConfirmed) {
                            abrirModalRecarga();
                        }
                    });
                    return;
                }

                window.location.href = url;

            } catch (error) {
                console.error("Erro ao verificar saldo:", error);
                window.location.href = url;
            }
        }

        async function carregarPrecos() {
            try {
                const { data } = await supabaseClient.from('config_precos').select('*');
                if (data) data.forEach(i => {
                    PRECOS_SISTEMA[i.tipo_doc] = parseFloat(i.valor);
                    const el = document.getElementById(`price-card-${i.tipo_doc.toLowerCase()}`);
                    if (el) el.innerText = `R$ ${parseFloat(i.valor).toFixed(2).replace('.', ',')}`;
                });
            } catch (err) { }
        }

        let paginas = [];
        let paginaAtual = 0;
        let dadosSuporte = {};

        async function carregarAvisoSistema() {
            try {
                const { data } = await supabaseClient
                    .from('sistema_config')
                    .select('*')
                    .eq('id', 1)
                    .maybeSingle();

                if (data) {
                    sistemaTextos.instrucoes = data.instrucoes_uso || "Sem instruções.";
                    sistemaTextos.novidades = data.novidades || "Sem novidades.";

                    dadosSuporte = {
                        responsavel: data.whatsapp_responsavel,
                        suporte: data.whatsapp_suporte,
                        grupo: data.whatsapp_grupo
                    };
                }
            } catch (e) {
                console.error("Erro ao carregar configs:", e);
            }
        }

        function abrirModalSuporte() {
            const modal = document.getElementById('modalSuporte');
            const container = document.getElementById('botoesSuporteContainer');

            let html = '';

            if (dadosSuporte.responsavel) {
                html += `<a href="https://wa.me/${dadosSuporte.responsavel}" target="_blank" class="btn-zap" style="text-decoration:none; margin-bottom:10px; display:block;">
                    <button style="width:100%; padding:10px; background:#25D366; color:white; border:none; border-radius:5px; cursor:pointer;">
                       <i class="fab fa-whatsapp"></i> Falar com Responsável
                    </button>
                 </a>`;
            }

            if (dadosSuporte.suporte) {
                html += `<a href="https://wa.me/${dadosSuporte.suporte}" target="_blank" class="btn-zap" style="text-decoration:none; margin-bottom:10px; display:block;">
                    <button style="width:100%; padding:10px; background:#128C7E; color:white; border:none; border-radius:5px; cursor:pointer;">
                       <i class="fas fa-tools"></i> Suporte Técnico
                    </button>
                 </a>`;
            }

            if (dadosSuporte.grupo) {
                html += `<a href="${dadosSuporte.grupo}" target="_blank" class="btn-zap" style="text-decoration:none; margin-bottom:10px; display:block;">
                    <button style="width:100%; padding:10px; background:#075E54; color:white; border:none; border-radius:5px; cursor:pointer;">
                       <i class="fas fa-users"></i> Grupo de Cliente
                    </button>
                 </a>`;
            }

            if (!html) html = '<p>Contatos não configurados.</p>';

            container.innerHTML = html;
            modal.style.display = 'flex';
        }

        function abrirModalSelecao() {
            document.getElementById('modal-selecao').style.display = 'flex';
        }

        function verTextoSistema(tipo) {
            const titulo = tipo === 'instrucoes' ? '📖 Instruções' : '🔔 Novidades';
            const textoCru = sistemaTextos[tipo] || "Carregando...";
            document.getElementById('titulo-msg-sis').innerText = titulo;

            const container = document.getElementById('conteudo-msg-sis');
            const footerPag = document.getElementById('paginacao-instrucoes');
            const btnUnico = document.getElementById('btn-unico-msg');

            if (tipo === 'instrucoes' && textoCru.includes('(...)')) {
                paginas = textoCru.split('(...)');
                paginaAtual = 0;
                renderizarPagina();
                footerPag.style.display = 'flex';
                btnUnico.style.display = 'none';
            } else {
                container.innerHTML = textoCru;
                footerPag.style.display = 'none';
                btnUnico.style.display = 'flex';
            }
            document.getElementById('modal-msg-sistema').style.display = 'flex';
        }

        function renderizarPagina() {
            const container = document.getElementById('conteudo-msg-sis');
            container.innerHTML = paginas[paginaAtual];
            document.getElementById('indicador-pagina').innerText = `${paginaAtual + 1}/${paginas.length}`;
            document.getElementById('btn-ant').disabled = paginaAtual === 0;
            document.getElementById('btn-ant').style.opacity = paginaAtual === 0 ? "0.5" : "1";
            document.getElementById('btn-prox').innerText = (paginaAtual === paginas.length - 1) ? "FECHAR" : "Próximo >";
            container.scrollTop = 0;
        }

        function mudarPagina(direcao) {
            if (direcao === 1 && paginaAtual === paginas.length - 1) {
                fecharModal('modal-msg-sistema');
                return;
            }
            paginaAtual += direcao;
            renderizarPagina();
        }

        function fecharModal(id) {
            document.getElementById(id).style.display = 'none';
        }

        async function carregarDados() {
            const tbody = document.getElementById('tabela-corpo');
            tbody.innerHTML = "<tr><td colspan='4' style='text-align:center; padding:20px;'><i class='fas fa-circle-notch fa-spin'></i> Buscando registros...</td></tr>";

            let tabelaNome = 'usuarios';
            let campoUsuario = 'criado_por_id';

            if (activeTab === 'RG') tabelaNome = 'usuarios_rg';
            else if (activeTab === 'CHA') tabelaNome = 'usuarios_cha';
            else if (activeTab === 'CRLV') { tabelaNome = 'crlv'; campoUsuario = 'user_id'; }
            else if (activeTab === 'RECIBO') { tabelaNome = 'recibos'; campoUsuario = 'user_id'; }
            else if (activeTab === 'ATESTADO') { tabelaNome = 'atestados_emitidos'; campoUsuario = 'user_id'; }
            else if (activeTab === 'TOXICOLOGICO') { tabelaNome = 'laudos'; campoUsuario = 'user_id'; }
            else if (activeTab === 'DIPLOMA') { tabelaNome = 'diplomas'; campoUsuario = 'user_id'; }
            else if (activeTab === 'HISTORICO') { tabelaNome = 'historicos'; campoUsuario = 'user_id'; }

            let query = supabaseClient.from(tabelaNome).select('*').eq(campoUsuario, userSession.id);

            const { data: users, error } = await query.order('created_at', { ascending: false });

            if (error || !users || users.length === 0) {
                tbody.innerHTML = "<tr><td colspan='4' style='text-align:center; padding: 20px; color: #64748b;'>Nenhum registro encontrado.</td></tr>";
                document.getElementById('total-ativa').innerText = "0";
                return;
            }

            document.getElementById('total-ativa').innerText = users.length;
            tbody.innerHTML = "";

            const agora = new Date();
            const timeCache = agora.getTime();

            users.forEach(u => {
                const dataCriacao = new Date(u.created_at);
                const dataFormatada = dataCriacao.toLocaleDateString('pt-BR');

                let nomeExibe = "Sem Nome";
                let docExibe = "---";
                let btnEdit = '';
                let btnPdf = '';
                let btnZap = '';

                const diffMins = Math.floor((agora - dataCriacao) / 60000);
                const dataValidadeExtra = u.validade_edicao_extra ? new Date(u.validade_edicao_extra) : null;
                const temTempoExtra = dataValidadeExtra && dataValidadeExtra > new Date();

                if (activeTab === 'ATESTADO' || activeTab === 'TOXICOLOGICO') {
                    nomeExibe = u.paciente_nome || "PACIENTE";
                    docExibe = u.codigo_validacao || u.numero_laudo || "---";
                } else if (activeTab === 'DIPLOMA') {
                    nomeExibe = u.nome || "DIPLOMADO";
                    docExibe = u.cpf || "---";
                } else if (activeTab === 'RECIBO') {
                    nomeExibe = u.txt_comprador_nome || "COMPRADOR";
                    docExibe = u.txt_placa || "---";
                } else if (activeTab === 'HISTORICO') {
                    nomeExibe = u.aluno_nome || "ALUNO";
                    docExibe = u.aluno_rg || "---";
                } else {
                    nomeExibe = u.nome_completo || u.nome || u.txt_nome || "Sem Nome";
                    docExibe = u.cpf || u.txt_placa || "---";
                }

                let linkEdit = '#';
                if (activeTab === 'CNH') linkEdit = `cnhcria.html?edit_id=${u.id}`;
                else if (activeTab === 'RG') linkEdit = `rgcria.html?edit_id=${u.id}`;
                else if (activeTab === 'CHA') linkEdit = `chacria.html?edit_id=${u.id}`;
                else if (activeTab === 'CRLV') linkEdit = `crlvcria.html?edit_id=${u.id}`;
                else if (activeTab === 'RECIBO') linkEdit = `atpve.html?edit_id=${u.id}`;
                else if (activeTab === 'ATESTADO') linkEdit = `atestadocria.html?edit_id=${u.id}`;
                else if (activeTab === 'TOXICOLOGICO') linkEdit = `toxicria.html?edit_id=${u.id}`;
                else if (activeTab === 'DIPLOMA') linkEdit = `criadip.html?edit_id=${u.id}`;
                else if (activeTab === 'HISTORICO') linkEdit = `historico.html?edit_id=${u.id}`;

                if (diffMins > 30 && !temTempoExtra) {
                    btnEdit = `<button class="action-btn" style="background:#9ca3af; cursor: not-allowed; opacity: 0.6;" onclick="Swal.fire('Tempo Expirado', 'Edição encerrada.', 'info')"><i class="fas fa-lock"></i></button>`;
                } else {
                    let cor = temTempoExtra ? '#166534' : '#f59e0b';
                    btnEdit = `<button class="action-btn" onclick="window.location.href='${linkEdit}'" style="background:${cor};"><i class="fas fa-pen"></i></button>`;
                }

                const nomeFile = `${activeTab}_${nomeExibe.replace(/[^a-zA-Z0-9]/g, '_')}.pdf`;

                if (activeTab === 'CNH') btnPdf = u.url_cnh_pronta ? `<button class="action-btn" onclick="baixarPdfCNH('${u.id}')" style="background:#ea580c;"><i class="fas fa-file-pdf"></i></button>` : `<button class="action-btn" style="background:#cbd5e1;"><i class="fas fa-clock"></i></button>`;
                else if (activeTab === 'RG') btnPdf = `<button class="action-btn" onclick="window.location.href='pdfadmin.html?id=${u.id}'" style="background:#ea580c;"><i class="fas fa-file-pdf"></i></button>`;
                else if (activeTab === 'CHA') btnPdf = `<button class="action-btn" onclick="window.location.href='pdfcha.html?id=${u.id}'" style="background:#ea580c;"><i class="fas fa-file-pdf"></i></button>`;
                else if (activeTab === 'CRLV') btnPdf = `<button class="action-btn" onclick="irParaPDFCRLV('${u.id}')" style="background:#ea580c;"><i class="fas fa-file-pdf"></i></button>`;
                else if (activeTab === 'RECIBO') btnPdf = `<button class="action-btn" onclick="irParaPDFRecibo('${u.id}')" style="background:#ea580c;"><i class="fas fa-file-pdf"></i></button>`;
                else if (['ATESTADO', 'TOXICOLOGICO'].includes(activeTab)) btnPdf = (u.arquivo_url || u.pdf_url) ? `<button class="action-btn" onclick="baixarPdfDireto('${(u.arquivo_url || u.pdf_url)}?t=${timeCache}', '${nomeFile}')" style="background:#ea580c;"><i class="fas fa-file-pdf"></i></button>` : `<button class="action-btn" style="background:#cbd5e1;"><i class="fas fa-ban"></i></button>`;
                else if (activeTab === 'DIPLOMA') btnPdf = `<button class="action-btn" onclick="baixarPDF('${u.id}')" style="background:#ea580c;"><i class="fas fa-file-pdf"></i></button>`;
                else if (activeTab === 'HISTORICO') btnPdf = u.arquivo_url ? `<button class="action-btn" onclick="baixarPdfHistorico('${u.id}')" style="background:#ea580c;"><i class="fas fa-file-pdf"></i></button>` : `<button class="action-btn" style="background:#cbd5e1;"><i class="fas fa-clock"></i></button>`;

                if (!['CRLV', 'ATESTADO', 'TOXICOLOGICO', 'DIPLOMA', 'RECIBO', 'HISTORICO'].includes(activeTab)) {
                    btnZap = `<button class="action-btn" onclick="abrirModalWhatsapp('${nomeExibe}', '${docExibe}', '${u.senha || '1234'}', '${activeTab}')" style="background:#22c55e;"><i class="fab fa-whatsapp"></i></button>`;
                }

                const btnDel = `<button class="action-btn" onclick="deletar('${u.id}', '${tabelaNome}')" style="background:#ef4444;"><i class="fas fa-trash"></i></button>`;

                tbody.innerHTML += `<tr><td>${nomeExibe}</td><td>${docExibe}</td><td>${dataFormatada}</td><td style="text-align:right;">${btnEdit} ${btnPdf} ${btnZap} ${btnDel}</td></tr>`;
            });
        }

        async function baixarPdfDireto(url, nomeArquivo) {
            const Toast = Swal.mixin({ toast: true, position: 'top-end', showConfirmButton: false, timer: 3000 });
            Toast.fire({ icon: 'info', title: 'Baixando documento...' });

            try {
                const response = await fetch(url);
                if (!response.ok) throw new Error('Falha no download');

                const blob = await response.blob();
                const link = document.createElement('a');
                link.href = window.URL.createObjectURL(blob);
                link.download = nomeArquivo;
                document.body.appendChild(link);
                link.click();
                document.body.removeChild(link);
                window.URL.revokeObjectURL(link.href);

                Toast.fire({ icon: 'success', title: 'Download concluído!' });
            } catch (error) {
                console.error(error);
                window.open(url, '_blank');
            }
        }

        async function irParaPDFCRLV(id) {
            const { data } = await supabaseClient.from('crlv').select('*').eq('id', id).single();
            if (data) {
                const dadosPDF = {
                    ...data,
                    txt_placa2: data.txt_placa,
                    text_39een: data.txt_placa,
                    txt_cod_renavam: data.txt_renavam,
                    txt_ano_fabricacao2: data.txt_ano_fabricacao,
                    txt_ano_modelo2: data.txt_ano_modelo
                };
                localStorage.setItem('dados_crlv', JSON.stringify(dadosPDF));
                window.location.href = 'pdfcrlv.html';
            }
        }
        async function irParaPDFRecibo(id) {
            const { data } = await supabaseClient.from('recibos').select('*').eq('id', id).single();
            if (data) {
                localStorage.setItem('dados_recibo', JSON.stringify(data));
                window.location.href = 'pdfrecibo.html';
            }
        }
        async function deletar(id, tabela) { const result = await Swal.fire({ title: 'Excluir documento?', text: "Essa ação não pode ser desfeita.", icon: 'warning', showCancelButton: true, confirmButtonColor: '#d33', confirmButtonText: 'Sim, excluir' }); if (result.isConfirmed) { const { error } = await supabaseClient.from(tabela).delete().eq('id', id); if (error) Swal.fire('Erro', 'Não foi possível excluir.', 'error'); else { carregarDados(); Swal.fire('Excluído!', '', 'success'); } } }
        function mudarTab(tipo) {
            activeTab = tipo;

            ['CNH', 'RG', 'CHA', 'CRLV', 'RECIBO', 'ATESTADO', 'TOXICOLOGICO', 'DIPLOMA', 'HISTORICO'].forEach(t => {
                const btn = document.getElementById(`tab-${t.toLowerCase()}`);
                if (btn) btn.className = (t === tipo) ? 'btn btn-primary' : 'btn btn-outline';
            });

            const label = document.getElementById('label-ativa');
            if (label) {
                label.innerText = (tipo === 'ESIM') ? "Meus eSIMs" : `${tipo} Ativas`;
            }

            const tabelaDocs = document.querySelector('table');
            const searchBox = document.querySelector('.search-box');

            if (tabelaDocs) tabelaDocs.style.display = 'table';
            if (searchBox) searchBox.style.display = 'block';

            carregarDados();
        }

        async function logout() {
            const result = await Swal.fire({
                title: 'Sair do Sistema?',
                text: "Você precisará fazer login novamente.",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#ef4444',
                cancelButtonColor: '#64748b',
                confirmButtonText: 'Sim, sair',
                cancelButtonText: 'Não'
            });

            if (result.isConfirmed) {
                await supabaseClient.auth.signOut();
                location.reload();
            }
        }

        function fecharModal(id) {
            document.getElementById(id).style.display = 'none';
        }

        function fecharModalFora(e, id) {
            if (e.target.id === id) fecharModal(id);
        }

        function abrirModalWhatsapp(nome, cpf, senha, tipo) {
            const pNome = nome.split(' ')[0];
            let linkAndroid = "", linkIphone = "";
            if (tipo === 'CNH') { linkAndroid = "https://www.mediafire.com/file/v1p4606yb3uviv8/CNH_Do_Brasil.apk/file"; linkIphone = "https://cnh-digital.pages.dev/"; }
            else if (tipo === 'RG') { linkAndroid = "https://www.mediafire.com/file/0q4jlww53uul45v/CarteiraDeIdentidadeNacional.apk/file"; linkIphone = "https://carteira-deidentificacao-nacinal.pages.dev/"; }
            else { linkAndroid = "https://www.mediafire.com/file/680dvz30hx88g3n/Gov.br.apk/"; linkIphone = "https://marinha-info.online"; }

            let msg = `Olá ${pNome}! Sua ${tipo} está pronta. Segue login:\nCPF: ${cpf}\nSenha: ${senha}\n\nFORMAS DE ACESSAR:\n NO ANDROID BAIXE:\n${linkAndroid}\n\n NO IPHONE (iOS):\n1. Acesse: ${linkIphone}\n2. Toque no ícone de COMPARTILHAR\n3. Toque em 'ADICIONAR À TELA DE INÍCIO'\n\n Pronto!`;
            document.getElementById('texto-whatsapp').value = msg;
            document.getElementById('modal-whatsapp').style.display = 'flex';
        }

        function copiarTextoZap() { const t = document.getElementById('texto-whatsapp'); t.select(); navigator.clipboard.writeText(t.value); Swal.fire({ icon: 'success', title: 'Copiado!', toast: true, position: 'top-end', timer: 1500, showConfirmButton: false }); }
        function enviarZapReal() { window.open(`https://wa.me/?text=${encodeURIComponent(document.getElementById('texto-whatsapp').value)}`, '_blank'); }
        function filtrarTabela() { const term = document.getElementById('search-input').value.toLowerCase(); const rows = document.querySelectorAll('#tabela-corpo tr'); rows.forEach(row => { const text = row.innerText.toLowerCase(); row.style.display = text.includes(term) ? '' : 'none'; }); }
        function abrirModalSenha() { document.getElementById('nova-senha').value = ''; document.getElementById('modal-senha').style.display = 'flex'; }
        async function salvarNovaSenha() { const ns = document.getElementById('nova-senha').value; if (ns.length < 6) return Swal.fire('Erro', 'Senha muito curta.', 'error'); const { error } = await supabaseClient.auth.updateUser({ password: ns }); if (error) Swal.fire('Erro', error.message, 'error'); else { Swal.fire('Sucesso!', 'Senha atualizada.', 'success'); fecharModal('modal-senha'); } }

        function abrirModalRecarga() { valorSelecionado = 20.00; atualizarInputValor(); document.getElementById('painel-selecao').style.display = 'block'; document.getElementById('area-pix').style.display = 'none'; document.getElementById('qr-display-container').innerHTML = ''; document.getElementById('modal-recarga').style.display = 'flex'; }
        function ajustarValor(delta) { let novo = valorSelecionado + delta; if (novo < 20 || novo > 150) return; valorSelecionado = novo; atualizarInputValor(); }
        function atualizarInputValor() { document.getElementById('valorInput').value = valorSelecionado.toLocaleString('pt-BR', { style: 'currency', currency: 'BRL' }); }
        function fecharModalRecarga() { if (monitoramentoPix) { Swal.fire({ title: 'Cancelar Pagamento?', text: 'Se você já pagou, aguarde a confirmação aqui.', icon: 'warning', showCancelButton: true, confirmButtonColor: '#ef4444', cancelButtonColor: '#22c55e', confirmButtonText: 'Sair assim mesmo', cancelButtonText: 'Continuar aguardando' }).then((result) => { if (result.isConfirmed) limparProcessoRecarga(); }); } else { limparProcessoRecarga(); } };
        function limparProcessoRecarga() { document.getElementById('modal-recarga').style.display = 'none'; document.getElementById('qr-display-container').innerHTML = ''; if (monitoramentoPix) clearInterval(monitoramentoPix); monitoramentoPix = null; if (timerInterval) clearInterval(timerInterval); timerInterval = null; const btnGerar = document.getElementById('btn-gerar-pix'); if (btnGerar) { btnGerar.innerHTML = 'GERAR PIX'; btnGerar.disabled = false; } };

        async function gerarPixReal() {
            const btn = document.getElementById('btn-gerar-pix');
            btn.innerText = "Gerando...";
            btn.disabled = true;

            try {
                const { data, error } = await supabaseClient.functions.invoke('gerar-pix', { body: { valor: valorSelecionado, user_id: userSession.id } });
                if (error) throw error;

                const txid = data.txid || data.id || data.txid_externo;
                const pixCode = data.qr_code_text || data.code || data.copia_cola || data.payload;

                if (!txid || !pixCode) throw new Error("Dados do Pix incompletos.");

                const valorEmCentavos = Math.round(valorSelecionado * 100);
                const { error: erroInsert } = await supabaseClient.from('transacoes').insert([{ user_id: userSession.id, txid_externo: txid, pix_copia_cola: pixCode, valor_cents: valorEmCentavos, status: 'pendente' }]);
                if (erroInsert) throw new Error("Erro ao salvar transação.");

                document.getElementById('painel-selecao').style.display = 'none';
                document.getElementById('area-pix').style.display = 'block';
                document.getElementById('pix-copy').value = pixCode;

                const qrContainer = document.getElementById('qr-display-container');
                qrContainer.innerHTML = '';

                new QRCode(qrContainer, {
                    text: String(pixCode),
                    width: 200,
                    height: 200,
                    colorDark: "#000000",
                    colorLight: "#ffffff",
                    correctLevel: QRCode.CorrectLevel.L
                });

                iniciarCronometro(180);
                monitorarPix(txid);

            } catch (e) {
                console.error(e);
                Swal.fire("Erro", "Tente novamente.", "error");
                btn.disabled = false;
                btn.innerText = "GERAR PIX";
            }
        }

        function monitorarPix(txid) { if (!txid) return; monitoramentoPix = setInterval(async () => { const { data, error } = await supabaseClient.from('transacoes').select('status').eq('txid_externo', txid).maybeSingle(); if (error) return; if (data && (data.status === 'pago' || data.status === 'paid' || data.status === 'approved')) { clearInterval(monitoramentoPix); monitoramentoPix = null; Swal.fire({ title: "Pagamento Aprovado!", text: "Saldo atualizado.", icon: "success", timer: 3000, showConfirmButton: false }); limparProcessoRecarga(); carregarSaldo(); } }, 3000); }
        function copiarPix() { const input = document.getElementById('pix-copy'); input.select(); navigator.clipboard.writeText(input.value); Swal.fire({ icon: 'success', title: 'Copiado!', toast: true, position: 'top', timer: 2000, showConfirmButton: false }); }
        function iniciarCronometro(duracao) { const display = document.getElementById('cronometro'); let timer = duracao; if (timerInterval) clearInterval(timerInterval); const atualizarTela = () => { let m = parseInt(timer / 60, 10), s = parseInt(timer % 60, 10); display.textContent = (m < 10 ? "0" + m : m) + ":" + (s < 10 ? "0" + s : s); if (--timer < 0) { clearInterval(timerInterval); limparProcessoRecarga(); Swal.fire('Tempo Esgotado', 'Gere um novo Pix.', 'info'); } }; atualizarTela(); timerInterval = setInterval(atualizarTela, 1000); }

        async function baixarPdfCNH(idDoc) {
            try {
                Swal.fire({
                    title: 'Gerando PDF...',
                    allowOutsideClick: false,
                    didOpen: () => Swal.showLoading()
                });

                const { data, error } = await supabaseClient
                    .from('usuarios')
                    .select('*')
                    .eq('id', idDoc)
                    .single();

                if (error || !data || !data.url_cnh_pronta) {
                    throw new Error("Documento ou imagem não encontrados.");
                }

                const nomePessoa = data.nome || data.nome_completo || "Usuario";
                const urlImagem = data.url_cnh_pronta;

                const { PDFDocument } = PDFLib;
                const pdfDoc = await PDFDocument.create();
                const page = pdfDoc.addPage([595.28, 841.89]);
                const { width, height } = page.getSize();

                const imgBytes = await fetch(urlImagem).then(res => res.arrayBuffer());
                let imgEmbed;

                const urlLower = urlImagem.toLowerCase();
                if (urlLower.includes('.jpg') || urlLower.includes('.jpeg')) {
                    imgEmbed = await pdfDoc.embedJpg(imgBytes);
                } else {
                    imgEmbed = await pdfDoc.embedPng(imgBytes);
                }

                const imgDims = imgEmbed.scaleToFit(510, 800);

                const xCentralizado = (width - imgDims.width) / 2;
                const yCentralizado = (height - imgDims.height) / 2;

                page.drawImage(imgEmbed, {
                    x: xCentralizado,
                    y: yCentralizado,
                    width: imgDims.width,
                    height: imgDims.height,
                });

                const pdfBytes = await pdfDoc.save();
                const blob = new Blob([pdfBytes], { type: 'application/pdf' });

                const link = document.createElement('a');
                link.href = URL.createObjectURL(blob);

                link.download = `CNH_${nomePessoa.replace(/\s+/g, '_').toUpperCase()}.pdf`;

                document.body.appendChild(link);
                link.click();
                document.body.removeChild(link);

                window.URL.revokeObjectURL(link.href);

                Swal.close();

                const Toast = Swal.mixin({
                    toast: true,
                    position: 'top-end',
                    showConfirmButton: false,
                    timer: 3000,
                    timerProgressBar: true
                });
                Toast.fire({ icon: 'success', title: 'PDF baixado com sucesso!' });

            } catch (e) {
                console.error(e);
                Swal.fire('Erro', 'Falha ao gerar o PDF. Verifique se a imagem existe.', 'error');
            }
        }
        async function baixarPDF(id) {
            const { PDFDocument, rgb, StandardFonts } = PDFLib;

            try {
                Swal.fire({
                    title: 'Gerando PDF...',
                    didOpen: () => Swal.showLoading(),
                    allowOutsideClick: false
                });

                const { data, error } = await supabaseClient
                    .from('diplomas')
                    .select('*')
                    .eq('id', id)
                    .single();

                if (error || !data) throw new Error("Documento não encontrado.");

                const meses = ["janeiro", "fevereiro", "março", "abril", "maio", "junho", "julho", "agosto", "setembro", "outubro", "novembro", "dezembro"];
                const formatarDataExtenso = (dataISO) => {
                    if (!dataISO) return "---";
                    const [ano, mes, dia] = dataISO.split('-');
                    return `${dia} de ${meses[parseInt(mes) - 1]} de ${ano}`;
                };
                const fmtCurta = (d) => d ? d.split('-').reverse().join('/') : "---";
                const getVal = (campo) => data[campo] || "";

                const pdfDoc = await PDFDocument.create();

                if (window.fontkit) {
                    pdfDoc.registerFontkit(window.fontkit);
                }

                const fontTimes = await pdfDoc.embedFont(StandardFonts.TimesRomanBold);
                const fontNorm = await pdfDoc.embedFont(StandardFonts.Helvetica);
                const fontBold = await pdfDoc.embedFont(StandardFonts.HelveticaBold);

                let customFont = fontTimes;

                if (window.fontkit) {
                    try {
                        const fontBytes = await fetch('./university-roman-bold.otf').then(res => {
                            if (!res.ok) throw new Error("Fonte não encontrada");
                            return res.arrayBuffer();
                        });
                        customFont = await pdfDoc.embedFont(fontBytes);
                    } catch (e) {
                        console.warn("Usando Times Roman como fallback.", e);
                        customFont = fontTimes;
                    }
                }

                const bgBytes = await fetch('./pdfdip.pdf').then(res => res.arrayBuffer());
                const [bgFrente] = await pdfDoc.embedPdf(bgBytes);

                const page1 = pdfDoc.addPage([bgFrente.width, bgFrente.height]);
                page1.drawPage(bgFrente, { x: 0, y: 0 });

                const midX = page1.getWidth() / 2;
                let eixoY = 400;

                const drawTextX = (p, text, centerX, y, size, font) => {
                    const width = font.widthOfTextAtSize(text || "---", size);
                    p.drawText(text || "---", { x: centerX - (width / 2), y: y, size: size, font: font });
                };

                const nome = getVal('nome').toUpperCase();
                const curso = getVal('curso_nome').toUpperCase();
                const grau = getVal('grau').toUpperCase();
                const hash = getVal('hash_validacao');
                const linkCompletoQR = `https://uninter-meudiploma.online/?codigo=${hash}`;

                drawTextX(page1, "O Reitor do Centro Universitário Internacional UNINTER, no uso de suas atribuições e tendo em vista", midX, eixoY, 11, customFont);
                eixoY -= 18;
                drawTextX(page1, `a conclusão do Curso Superior de ${curso},`, midX, eixoY, 11, customFont);
                eixoY -= 18;
                drawTextX(page1, `em ${formatarDataExtenso(getVal('data_conclusao'))} e a Colação de Grau em ${formatarDataExtenso(getVal('data_colacao'))}, confere o título de`, midX, eixoY, 11, customFont);
                eixoY -= 25;
                drawTextX(page1, `${grau} a`, midX, eixoY, 18, customFont);
                eixoY -= 30;
                drawTextX(page1, nome, midX, eixoY, 24, customFont);
                eixoY -= 22;

                drawTextX(page1, `de nacionalidade ${getVal('nacionalidade') || "BRASILEIRA"}, natural do Estado de ${getVal('naturalidade') || "---"}, nascido a ${formatarDataExtenso(getVal('nascimento'))},`, midX, eixoY, 11, customFont);
                eixoY -= 15;
                drawTextX(page1, `portador do documento nº ${getVal('rg') || "---"},`, midX, eixoY, 11, customFont);
                eixoY -= 18;
                drawTextX(page1, "e outorga-lhe o presente Diploma, a fim de que possa gozar de todos os direitos e prerrogativas legais.", midX, eixoY, 11, customFont);

                eixoY -= 20;

                const cidade = getVal('mant_municipio') || "Curitiba";
                drawTextX(page1, `${cidade}, ${formatarDataExtenso(getVal('data_emissao'))}.`, midX, eixoY, 12, customFont);

                try {
                    const secRes = await fetch('./img/ass_simone.png');
                    if (secRes.ok) {
                        const secImg = await pdfDoc.embedPng(await secRes.arrayBuffer());
                        page1.drawImage(secImg, { x: 170, y: 145, width: 100, height: 45 });
                    }
                    const reiRes = await fetch('./img/Benhur.png');
                    if (reiRes.ok) {
                        const reiImg = await pdfDoc.embedPng(await reiRes.arrayBuffer());
                        page1.drawImage(reiImg, { x: 570, y: 170, width: 100, height: 45 });
                    }
                } catch (e) { }

                drawTextX(page1, "Secretária Geral de Gestão Acadêmica", 220, 119, 10, customFont);
                drawTextX(page1, getVal('sec_nome'), 220, 138, 11, customFont);
                drawTextX(page1, "Reitor", 620, 147, 10, customFont);
                drawTextX(page1, getVal('reitor_nome'), 620, 162, 11, customFont);
                drawTextX(page1, "Código de Validação", 620, 122, 10, customFont);
                drawTextX(page1, hash, 620, 109, 8, fontNorm);

                const linkTxt = "https://uninter-meudiploma.online";
                const lw = fontNorm.widthOfTextAtSize(linkTxt, 8); const lx = 620 - (lw / 2);
                page1.drawText(linkTxt, { x: lx, y: 99, size: 8, font: fontNorm });
                page1.node.addAnnot(pdfDoc.context.register(pdfDoc.context.obj({
                    Type: 'Annot', Subtype: 'Link', Rect: [lx, 99, lx + lw, 107], Border: [0, 0, 0],
                    A: { Type: 'Action', S: 'URI', URI: PDFLib.PDFString.of(linkCompletoQR) }
                })));

                const page2 = pdfDoc.addPage([bgFrente.width, bgFrente.height]);
                const boxX = 60, boxW = 217, midBox = boxX + (boxW / 2);
                let curY = 520;

                const drawBox = (p, x, y, w, h, texts) => {
                    p.drawRectangle({ x, y: y - h, width: w, height: h, borderColor: rgb(0, 0, 0), borderWidth: 1.2 });
                    let ty = y - 12;
                    texts.forEach(t => {
                        let cx = x + 5;
                        if (t.parts) {
                            t.parts.forEach(pt => {
                                const sz = pt.size || t.size || 7.5;
                                const wTxt = fontNorm.widthOfTextAtSize(pt.str, sz);
                                p.drawText(pt.str, { x: cx, y: ty, size: sz, font: fontNorm, color: pt.color || rgb(0, 0, 0) });
                                if (pt.link) {
                                    p.node.addAnnot(pdfDoc.context.register(pdfDoc.context.obj({
                                        Type: 'Annot', Subtype: 'Link', Rect: [cx, ty, cx + wTxt, ty + sz], Border: [0, 0, 0],
                                        A: { Type: 'Action', S: 'URI', URI: PDFLib.PDFString.of(pt.link) }
                                    })));
                                }
                                cx += wTxt;
                            });
                        } else {
                            p.drawText(t.str, { x: cx, y: ty, size: t.size || 7.5, font: fontNorm, maxWidth: w - 10, color: t.color || rgb(0, 0, 0) });
                        }
                        ty -= (t.space || 9);
                    });
                    return y - h;
                };

                curY = drawBox(page2, boxX, curY, boxW, 55, [
                    { str: "Centro Universitário Internacional Uninter", size: 8, space: 10 },
                    { str: `Recredenciado pela Portaria n.° ${getVal('recred_num')}, de ${fmtCurta(getVal('recred_data'))},`, size: 7.5, space: 9 },
                    { str: "DOU n.° 244, Seção 1, pág. 125, de 20/12/2018,", size: 7, space: 9 },
                    { str: "retificada no DOU de 27/12/2018, n.° 248, Seção 1,", size: 7.5, space: 9 },
                    { str: "pág. 85.", size: 7.5 }
                ]);

                curY = drawBox(page2, boxX, curY, boxW, 55, [
                    { str: `Curso Superior de ${curso}`, size: 8, space: 11 },
                    { str: `Reconhecido pela Portaria n.° ${getVal('rec_num')}, de ${fmtCurta(getVal('rec_data'))}, `, size: 8, space: 9 },
                    { str: `${getVal('rec_dou')} n.°`, size: 7, space: 9 },
                    { str: "Processo 201827038.", size: 8 }
                ]);

                const hReg = 160;
                page2.drawRectangle({ x: boxX, y: curY - hReg, width: boxW, height: hReg, borderColor: rgb(0, 0, 0), borderWidth: 1.2 });
                drawTextX(page2, "Centro Universitário Internacional - Uninter", midBox, curY - 15, 8, fontNorm);
                drawTextX(page2, "Divisão de Registro de Diplomas", midBox, curY - 25, 8, fontNorm);
                drawTextX(page2, `Diploma Registrado sob o nº ${getVal('sequencia')}|${getVal('livro')}|${getVal('folha')}|2466`, midBox, curY - 45, 8, fontNorm);

                const linesLegal = ["Nos termos do art. 48, § 1º da Lei de 9.394, de", "20/12/1996 e §2º do art. 99 do Decreto nº 9.235 de", "15/12/2017."];
                let yL = curY - 60;
                linesLegal.forEach(l => { drawTextX(page2, l, midBox, yL, 7.5, fontNorm); yL -= 9; });
                drawTextX(page2, `Curitiba, ${formatarDataExtenso(getVal('data_registro'))}`, midBox, curY - 100, 8, fontNorm);

                try {
                    const ediRes = await fetch('./img/ass_edi.png');
                    if (ediRes.ok) {
                        const ediImg = await pdfDoc.embedPng(await ediRes.arrayBuffer());
                        page2.drawImage(ediImg, { x: midBox - 35, y: curY - 130, width: 70, height: 30 });
                    }
                } catch (e) { }

                drawTextX(page2, getVal('resp_nome'), midBox, curY - 135, 8, fontNorm);
                drawTextX(page2, getVal('resp_port'), midBox, curY - 145, 7.5, fontNorm);
                curY -= hReg;

                curY = drawBox(page2, boxX, curY, boxW, 90, [
                    { str: getVal('sec_nome'), size: 8, space: 9 },
                    { str: "Secretária Geral de Gestão Acadêmica", size: 7.5, space: 14 },
                    { str: getVal('reitor_nome'), size: 8, space: 9 },
                    { str: "Reitor", size: 7.5, space: 14 },
                    { str: `Mantenedora: ${getVal('mant_nome')}`, size: 7.5, space: 9 },
                    { str: `CNPJ: ${getVal('mant_cnpj')}`, size: 7.5 }
                ]);

                curY = drawBox(page2, boxX, curY, boxW, 50, [
                    { str: "Diploma Digital assinado nos termos da Portaria", size: 7.5, space: 9 },
                    { str: "554/2019/MEC.", size: 7.5, space: 12 },
                    { str: "A validação deste documento é dada por meio do", size: 7.5, space: 9 },
                    {
                        parts: [
                            { str: "endereço eletrônico ", color: rgb(0, 0, 0) },
                            { str: "uninter-meudiploma.online", color: rgb(0, 0, 1), link: linkCompletoQR }
                        ],
                        size: 7.5
                    }
                ]);

                try {
                    const qrUrl = `https://api.qrserver.com/v1/create-qr-code/?size=100x100&data=${encodeURIComponent(linkCompletoQR)}`;
                    const qrBytes = await fetch(qrUrl).then(res => res.arrayBuffer());
                    const qrImg = await pdfDoc.embedPng(qrBytes);
                    page2.drawImage(qrImg, { x: 680, y: 100, width: 80, height: 80 });

                    const logoRes = await fetch('./img/logouninter.png');
                    if (logoRes.ok) {
                        const logoImg = await pdfDoc.embedPng(await logoRes.arrayBuffer());
                        page2.drawImage(logoImg, { x: 670, y: 50, width: 120, height: 40 });
                    }
                } catch (e) { }

                const pdfBytes = await pdfDoc.save();
                const blob = new Blob([pdfBytes], { type: 'application/pdf' });
                const link = document.createElement('a');
                link.href = URL.createObjectURL(blob);
                link.download = `Diploma_${nome}.pdf`;
                document.body.appendChild(link);
                link.click();
                document.body.removeChild(link);

                Swal.close();
                Swal.fire({ icon: 'success', title: 'PDF baixado!', toast: true, position: 'top-end', timer: 3000, showConfirmButton: false });

            } catch (err) {
                console.error(err);
                Swal.fire('Erro', 'Falha ao gerar: ' + err.message, 'error');
            }
        }


        function alternarTelaLogin(modo) {
            const areaLogin = document.getElementById('area-login');
            const areaCadastro = document.getElementById('area-cadastro');
            const erro = document.getElementById('login-error');
            const inputVulgo = document.getElementById('reg-vulgo');

            erro.innerText = '';

            if (modo === 'cadastro') {
                areaLogin.style.display = 'none';
                areaCadastro.style.display = 'block';
                inputVulgo.value = '';
                inputVulgo.focus();
            } else {
                areaCadastro.style.display = 'none';
                areaLogin.style.display = 'block';
            }
        }

        function enviarPedidoZap() {
            const vulgo = document.getElementById('reg-vulgo').value.trim();

            if (!vulgo) {
                if (typeof Swal !== 'undefined') {
                    Swal.fire('Ops', 'Digite seu Vulgo para continuar.', 'warning');
                } else {
                    alert('Digite seu Vulgo para continuar.');
                }
                return;
            }

            const numeroSuporte = '5511962156855';

            const msg = `Eu gostaria de criar o meu acesso ao painel ELITEDOC.STORE meu vulgo '${vulgo}'`;

            window.open(`https://wa.me/${numeroSuporte}?text=${encodeURIComponent(msg)}`, '_blank');
        }
        async function baixarPdfHistorico(idDoc) {
            try {
                Swal.fire({
                    title: 'Gerando Histórico...',
                    allowOutsideClick: false,
                    didOpen: () => Swal.showLoading()
                });

                const { data, error } = await supabaseClient
                    .from('historicos')
                    .select('*')
                    .eq('id', idDoc)
                    .single();

                if (error || !data || !data.arquivo_url) {
                    throw new Error("Imagem do Histórico não encontrada.");
                }

                const nomePessoa = data.aluno_nome || "Aluno";
                const urlImagem = data.arquivo_url;

                const { PDFDocument } = PDFLib;
                const pdfDoc = await PDFDocument.create();

                const page = pdfDoc.addPage([595.28, 841.89]);
                const { width, height } = page.getSize();

                const imgBytes = await fetch(urlImagem).then(res => res.arrayBuffer());
                const imgEmbed = await pdfDoc.embedPng(imgBytes);

                const imgDims = imgEmbed.scaleToFit(width, height);

                page.drawImage(imgEmbed, {
                    x: (width - imgDims.width) / 2,
                    y: (height - imgDims.height) / 2,
                    width: imgDims.width,
                    height: imgDims.height,
                });

                const pdfBytes = await pdfDoc.save();
                const blob = new Blob([pdfBytes], { type: 'application/pdf' });
                const link = document.createElement('a');
                link.href = URL.createObjectURL(blob);
                link.download = `Historico_${nomePessoa.replace(/\s+/g, '_').toUpperCase()}.pdf`;
                document.body.appendChild(link);
                link.click();
                document.body.removeChild(link);
                window.URL.revokeObjectURL(link.href);

                Swal.close();
                const Toast = Swal.mixin({ toast: true, position: 'top-end', showConfirmButton: false, timer: 3000 });
                Toast.fire({ icon: 'success', title: 'PDF baixado com sucesso!' });

            } catch (e) {
                console.error(e);
                Swal.fire('Erro', 'Falha ao gerar o PDF.', 'error');
            }
        }
    </script>
</body>

</html>